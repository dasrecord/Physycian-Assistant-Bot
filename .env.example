# ──────────────────────────────────────────────────────────────
# .env.example  — copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# ── OSCAR Pro ────────────────────────────────────────────────
# Full URL of your OSCAR Pro login page
OSCAR_URL=https://your-clinic.oscarpro.com/oscar/login.do
OSCAR_USERNAME=your_username
OSCAR_PASSWORD=your_password

# ── Doctor info (used for billing exports) ───────────────────
DOCTOR_LAST_NAME=YourLastName
DOCTOR_FIRST_NAME=YourFirstName
DOCTOR_BILLING_NUMBER=

# ── Local AI ─────────────────────────────────────────────────
# Ollama model to use for SOAP generation.
# Recommended: llama3.2:3b (fits in 2 GB RAM) | llama3.1:8b (needs 5 GB RAM)
# Run: ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434

# Whisper model size: tiny.en | base.en | small.en | medium.en | large-v3
# medium.en gives the best accuracy for medical dictation
WHISPER_MODEL=medium.en

# ── Server ───────────────────────────────────────────────────
# Port for the local web UI (open http://localhost:PORT in browser or phone)
PORT=5000
