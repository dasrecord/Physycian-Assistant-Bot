# Normalize line endings: LF in the repo, platform-native on checkout
* text=auto

# Shell scripts always LF (needed for Mac/Linux execution)
*.sh text eol=lf

# Batch files always CRLF
*.bat text eol=crlf

# Binary files — never mangle
*.bin binary
*.pt binary
*.onnx binary
*.webm binary
*.wav binary
*.mp3 binary
*.png binary
*.jpg binary
*.ico binary
